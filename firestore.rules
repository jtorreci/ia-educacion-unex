rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Función auxiliar: verificar si es admin
    function isAdmin() {
      return request.auth != null &&
             get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.rol == 'admin';
    }

    // Función auxiliar: verificar si es profesor
    function isProfesor() {
      return request.auth != null &&
             get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.rol == 'profesor';
    }

    // Centros participantes (universidades)
    // Lectura publica: la lista de universidades y sus dominios es informacion publica
    // Escritura solo admin: solo el administrador puede dar de alta centros
    match /centros/{centroId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Usuarios: lectura del propio perfil, escritura admin o profesor (alta estudiantes)
    match /usuarios/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow read: if isAdmin();
      allow write: if isAdmin();
      // Auto-registro: un usuario puede crear su propio documento como estudiante
      allow create: if request.auth != null &&
                      request.auth.token.email == email &&
                      request.resource.data.rol == 'estudiante' &&
                      request.resource.data.email == email;
      // Profesores pueden crear estudiantes nuevos (no sobreescribir usuarios existentes)
      allow create: if isProfesor() &&
                      request.resource.data.rol == 'estudiante';
      // Profesores pueden actualizar solo si el usuario YA era estudiante
      allow update: if isProfesor() &&
                      request.resource.data.rol == 'estudiante' &&
                      resource.data.rol == 'estudiante';
    }

    // Profesores pueden leer la lista de usuarios (para verificar roles)
    match /usuarios/{email} {
      allow read: if isProfesor() || isAdmin();
    }

    // Asignaturas
    match /asignaturas/{asigId} {
      // Profesores ven sus propias asignaturas, admin ve todas
      allow read: if request.auth != null;
      allow create: if isProfesor() || isAdmin();
      allow update, delete: if isAdmin() ||
                              (isProfesor() && resource.data.profesorEmail == request.auth.token.email);

      // Estudiantes de la asignatura (subcolección)
      match /estudiantes/{estEmail} {
        // Lectura: cualquier autenticado (necesario para conteo de grupos al inscribirse)
        allow read: if request.auth != null;
        allow write: if isProfesor() || isAdmin();
        // Auto-inscripción: un estudiante puede crear su propio documento de inscripción
        allow create: if request.auth != null &&
                        request.auth.token.email == estEmail;
        // Permitir a estudiantes actualizar su propio estado de completado
        allow update: if request.auth != null &&
                        request.auth.token.email == estEmail &&
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly([
                            'completado_pre', 'completado_reto1', 'completado_reto2', 'completado_post',
                            'audit_pre_total', 'audit_pre_respondidas', 'audit_pre_vacias', 'audit_pre_fecha',
                            'audit_reto1_total', 'audit_reto1_respondidas', 'audit_reto1_vacias', 'audit_reto1_fecha',
                            'audit_reto2_total', 'audit_reto2_respondidas', 'audit_reto2_vacias', 'audit_reto2_fecha',
                            'audit_post_total', 'audit_post_respondidas', 'audit_post_vacias', 'audit_post_fecha'
                          ]);
      }

      // Estudiantes de prueba (modo test del profesor) — paralelo a 'estudiantes'
      // El profesor dueño se auto-inscribe para recorrer el flujo sin contaminar datos reales.
      match /estudiantes_test/{estEmail} {
        // Lectura: admin, o el profesor dueño de la asignatura, o el propio usuario test
        allow read: if isAdmin() ||
                      (request.auth != null && request.auth.token.email == estEmail) ||
                      (isProfesor() &&
                        get(/databases/$(database)/documents/asignaturas/$(asigId)).data.profesorEmail == request.auth.token.email);
        // Creación: el propio usuario se inscribe como tester (solo él puede auto-crearse)
        allow create: if request.auth != null &&
                        request.auth.token.email == estEmail &&
                        request.resource.data.esTest == true;
        // Actualización/borrado: admin, el dueño de la asignatura, o el propio tester
        allow update, delete: if isAdmin() ||
                                (request.auth != null && request.auth.token.email == estEmail) ||
                                (isProfesor() &&
                                  get(/databases/$(database)/documents/asignaturas/$(asigId)).data.profesorEmail == request.auth.token.email);
      }
    }

    // Respuestas de cuestionarios - estudiantes escriben, solo admin lee el contenido real.
    // Para modo prueba (esTest=true), el profesor dueño de la asignatura puede leer y borrar
    // únicamente las respuestas marcadas como test y asociadas a él vía profesorEmail.
    function isTeacherOwnTest(data) {
      return isProfesor() &&
             data.esTest == true &&
             data.profesorEmail == request.auth.token.email;
    }

    // En creación test: exigimos coherencia (esTest true, profesorEmail = caller,
    // y caller dueño de la asignatura indicada).
    function validTestCreate() {
      return request.resource.data.esTest == true &&
             request.resource.data.profesorEmail == request.auth.token.email &&
             isProfesor() &&
             get(/databases/$(database)/documents/asignaturas/$(request.resource.data.asignaturaId)).data.profesorEmail == request.auth.token.email;
    }

    match /respuestas_pre/{docId} {
      allow create: if request.auth != null &&
                      (request.resource.data.esTest != true || validTestCreate());
      allow read: if isAdmin() || isTeacherOwnTest(resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin() || isTeacherOwnTest(resource.data);
    }

    match /respuestas_reto/{docId} {
      allow create: if request.auth != null &&
                      (request.resource.data.esTest != true || validTestCreate());
      allow read: if isAdmin() || isTeacherOwnTest(resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin() || isTeacherOwnTest(resource.data);
    }

    match /respuestas_post/{docId} {
      allow create: if request.auth != null &&
                      (request.resource.data.esTest != true || validTestCreate());
      allow read: if isAdmin() || isTeacherOwnTest(resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin() || isTeacherOwnTest(resource.data);
    }

    // Rúbricas - profesores escriben las de sus asignaturas, admin lee todas
    match /rubricas/{docId} {
      allow create: if isProfesor() || isAdmin();
      allow read: if isAdmin();
      allow update: if isProfesor() || isAdmin();
      allow delete: if isAdmin();
    }

    // Validacion experta de instrumentos
    // Cada persona experta mantiene su propio formulario; admin puede leer el conjunto
    match /validacion_instrumentos/{email} {
      allow create, update: if request.auth != null &&
                              (isProfesor() || isAdmin()) &&
                              request.auth.token.email == email;
      allow read: if isAdmin() ||
                    (request.auth != null &&
                     (isProfesor() || isAdmin()) &&
                     request.auth.token.email == email);
      allow delete: if isAdmin();
    }

    // Configuración global (titulaciones, etc.)
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
